{
  "name": "ai-coding-guide",
  "version": "1.0.0",
  "description": "AI 代码入门指南 - 给资深 C/云计算开发者",
  "scripts": {
    "start": "python3 -m http.server 8000",
    "test": "npm run test:unit && npm run test:system && npm run test:mcp",
    "test:unit": "jest tests/unit --coverage",
    "test:system": "playwright test tests/system",
    "test:mcp": "jest tests/mcp --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=html",
    "build:mcp": "tsc -p mcp/tsconfig.json",
    "mcp:start": "node mcp/dist/server.js",
    "mcp:validate": "ts-node mcp/tests/validate.ts",
    "lint": "eslint . --ext .js,.ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@testing-library/dom": "^9.13.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^24.0.0",
    "playwright": "^1.42.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "@modelcontextprotocol/sdk": "^0.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "roots": [
      "<rootDir>/tests"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "collectCoverageFrom": [
      "js/**/*.js",
      "mcp/src/**/*.ts",
      "!**/node_modules/**"
    ]
  },
  "keywords": [
    "ai",
    "coding",
    "cloud-computing",
    "kernel",
    "kvm",
    "mcp",
    "openclaw"
  ],
  "author": "OpenClaw Community",
  "license": "MIT"
}